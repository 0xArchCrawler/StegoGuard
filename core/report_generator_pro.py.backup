"""
Professional Forensic Report Generator with Advanced Visualizations
Generates stunning, high-level professional reports with interactive charts
"""

from datetime import datetime
from typing import Dict, List
import json


class ProForensicReportGenerator:
    """
    Generates absolutely stunning professional forensic reports
    with advanced visualizations, charts, and interactive elements
    """

    def __init__(self):
        self.report_id = self.generate_report_id()

    def generate_report_id(self) -> str:
        """Generate unique report ID"""
        now = datetime.now()
        return f"SG-{now.strftime('%Y%m%d-%H%M')}"

    def generate_html_report(self, analysis_results: Dict) -> str:
        """
        Generate STUNNING professional HTML forensic report
        with advanced visualizations, charts, and interactive elements
        """

        # Extract data
        file_info = analysis_results.get('file_info', {})
        threat_level = analysis_results.get('threat_level', 'unknown').upper()
        confidence = analysis_results.get('confidence', 0)
        anomaly_count = analysis_results.get('anomaly_count', 0)
        detection_score = analysis_results.get('detection_score', 0)
        detection_results = analysis_results.get('detection_results', [])
        decryption_results = analysis_results.get('decryption_results', {})
        threat_intel = analysis_results.get('threat_intel', {})

        # Calculate statistics for visualizations
        detected_count = sum(1 for d in detection_results if d.get('detected', False))
        clean_count = len(detection_results) - detected_count
        avg_confidence = sum(d.get('confidence', 0) for d in detection_results) / max(len(detection_results), 1)

        # Severity distribution
        severity_counts = {'critical': 0, 'high': 0, 'medium': 0, 'low': 0}
        for d in detection_results:
            if d.get('detected', False):
                severity = d.get('severity', 'unknown').lower()
                if severity in severity_counts:
                    severity_counts[severity] += 1

        # Decryption probe stats
        decryption_activated = decryption_results.get('activated', False)
        overall_success_rate = decryption_results.get('overall_success_rate', 0) if decryption_activated else 0
        probes = decryption_results.get('probes', []) if decryption_activated else []

        # Threat color
        threat_colors = {
            'CRITICAL': '#ef4444',
            'HIGH': '#f97316',
            'MEDIUM': '#eab308',
            'LOW': '#22c55e',
            'UNKNOWN': '#6b7280'
        }
        threat_color = threat_colors.get(threat_level, '#6b7280')

        html = f"""<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>StegoGuard Professional Forensic Report - {self.report_id}</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        * {{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }}

        body {{
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #0a0e27 0%, #16213e 100%);
            color: #e0e0e0;
            line-height: 1.6;
            padding: 40px 20px;
        }}

        .report-container {{
            max-width: 1400px;
            margin: 0 auto;
            background: rgba(26, 32, 53, 0.95);
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
            overflow: hidden;
            backdrop-filter: blur(10px);
        }}

        /* Header Section */
        .report-header {{
            background: linear-gradient(135deg, #00e5ff 0%, #00a8cc 50%, #005f73 100%);
            padding: 50px 60px;
            color: #0a0e27;
            position: relative;
            overflow: hidden;
        }}

        .report-header::before {{
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
            animation: pulse 15s ease-in-out infinite;
        }}

        @keyframes pulse {{
            0%, 100% {{ transform: scale(1); opacity: 0.5; }}
            50% {{ transform: scale(1.1); opacity: 0.8; }}
        }}

        .header-content {{
            position: relative;
            z-index: 1;
        }}

        .report-title {{
            font-size: 48px;
            font-weight: 700;
            margin-bottom: 15px;
            text-transform: uppercase;
            letter-spacing: 3px;
            text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
        }}

        .report-subtitle {{
            font-size: 24px;
            font-weight: 300;
            margin-bottom: 30px;
            opacity: 0.9;
        }}

        .header-meta {{
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 20px;
            margin-top: 30px;
        }}

        .meta-item {{
            background: rgba(10, 14, 39, 0.6);
            padding: 20px;
            border-radius: 12px;
            backdrop-filter: blur(10px);
        }}

        .meta-label {{
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            opacity: 0.8;
            margin-bottom: 8px;
        }}

        .meta-value {{
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }}

        /* Main Content */
        .report-body {{
            padding: 60px;
        }}

        .section {{
            margin-bottom: 60px;
            animation: fadeInUp 0.6s ease-out;
        }}

        @keyframes fadeInUp {{
            from {{
                opacity: 0;
                transform: translateY(30px);
            }}
            to {{
                opacity: 1;
                transform: translateY(0);
            }}
        }}

        .section-header {{
            display: flex;
            align-items: center;
            gap: 15px;
            margin-bottom: 30px;
            padding-bottom: 15px;
            border-bottom: 3px solid #00e5ff;
        }}

        .section-header i {{
            font-size: 32px;
            color: #00e5ff;
        }}

        .section-title {{
            font-size: 32px;
            font-weight: 700;
            color: #00e5ff;
            text-transform: uppercase;
            letter-spacing: 2px;
        }}

        /* Threat Assessment Card */
        .threat-card {{
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.1) 0%, rgba(239, 68, 68, 0.05) 100%);
            border: 2px solid {threat_color};
            border-radius: 16px;
            padding: 40px;
            position: relative;
            overflow: hidden;
        }}

        .threat-card::before {{
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, {threat_color}20 0%, transparent 70%);
            animation: rotate 20s linear infinite;
        }}

        @keyframes rotate {{
            from {{ transform: rotate(0deg); }}
            to {{ transform: rotate(360deg); }}
        }}

        .threat-content {{
            position: relative;
            z-index: 1;
        }}

        .threat-level-badge {{
            display: inline-block;
            background: {threat_color};
            color: #fff;
            padding: 20px 40px;
            border-radius: 12px;
            font-size: 36px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 3px;
            box-shadow: 0 10px 30px {threat_color}40;
            margin-bottom: 30px;
        }}

        .threat-stats-grid {{
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }}

        .stat-card {{
            background: rgba(26, 32, 53, 0.8);
            border: 1px solid rgba(0, 229, 255, 0.2);
            border-radius: 12px;
            padding: 25px;
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }}

        .stat-card:hover {{
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 229, 255, 0.3);
        }}

        .stat-label {{
            font-size: 14px;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: #00e5ff;
            margin-bottom: 10px;
        }}

        .stat-value {{
            font-size: 42px;
            font-weight: 700;
            color: #fff;
        }}

        .stat-subvalue {{
            font-size: 16px;
            color: #888;
            margin-top: 5px;
        }}

        /* Charts Container */
        .charts-grid {{
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 30px;
            margin-top: 30px;
        }}

        .chart-card {{
            background: rgba(26, 32, 53, 0.8);
            border: 1px solid rgba(0, 229, 255, 0.2);
            border-radius: 16px;
            padding: 30px;
        }}

        .chart-title {{
            font-size: 20px;
            font-weight: 600;
            color: #00e5ff;
            margin-bottom: 20px;
            text-align: center;
        }}

        .chart-container {{
            position: relative;
            height: 300px;
        }}

        /* Progress Bars */
        .progress-bar-container {{
            margin: 20px 0;
        }}

        .progress-label {{
            display: flex;
            justify-content: space-between;
            margin-bottom: 10px;
            font-size: 14px;
            color: #00e5ff;
        }}

        .progress-bar {{
            width: 100%;
            height: 30px;
            background: rgba(0, 0, 0, 0.3);
            border-radius: 15px;
            overflow: hidden;
            position: relative;
        }}

        .progress-fill {{
            height: 100%;
            background: linear-gradient(90deg, #00e5ff 0%, #00a8cc 100%);
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: flex-end;
            padding: 0 15px;
            font-weight: 600;
            transition: width 2s ease-out;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.5);
        }}

        /* Detection Results */
        .detection-grid {{
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
            gap: 25px;
        }}

        .detection-card {{
            background: rgba(26, 32, 53, 0.8);
            border-left: 5px solid #00e5ff;
            border-radius: 12px;
            padding: 25px;
            transition: all 0.3s ease;
        }}

        .detection-card.detected {{
            border-left-color: #ef4444;
            background: rgba(239, 68, 68, 0.1);
        }}

        .detection-card.clean {{
            border-left-color: #22c55e;
            background: rgba(34, 197, 94, 0.1);
        }}

        .detection-card:hover {{
            transform: translateX(5px);
            box-shadow: 0 10px 30px rgba(0, 229, 255, 0.2);
        }}

        .detection-header {{
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }}

        .detection-name {{
            font-size: 18px;
            font-weight: 600;
            color: #fff;
        }}

        .detection-status {{
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
        }}

        .status-detected {{
            background: #ef4444;
            color: #fff;
        }}

        .status-clean {{
            background: #22c55e;
            color: #fff;
        }}

        .detection-confidence {{
            font-size: 16px;
            color: #00e5ff;
            margin: 10px 0;
        }}

        .detection-severity {{
            display: inline-block;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            margin: 10px 0;
        }}

        .severity-critical {{
            background: #ef4444;
            color: #fff;
        }}

        .severity-high {{
            background: #f97316;
            color: #fff;
        }}

        .severity-medium {{
            background: #eab308;
            color: #000;
        }}

        .severity-low {{
            background: #22c55e;
            color: #fff;
        }}

        .detection-details {{
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid rgba(0, 229, 255, 0.2);
            font-size: 14px;
            line-height: 1.6;
            color: #ccc;
        }}

        .detection-type {{
            margin-top: 10px;
            font-size: 13px;
            color: #00e5ff;
            font-style: italic;
        }}

        /* Decryption Timeline */
        .probe-timeline {{
            position: relative;
            padding-left: 50px;
        }}

        .probe-timeline::before {{
            content: '';
            position: absolute;
            left: 20px;
            top: 0;
            bottom: 0;
            width: 4px;
            background: linear-gradient(180deg, #00e5ff 0%, #005f73 100%);
        }}

        .probe-item {{
            position: relative;
            margin-bottom: 40px;
            padding: 25px;
            background: rgba(26, 32, 53, 0.8);
            border-radius: 12px;
            border: 1px solid rgba(0, 229, 255, 0.2);
        }}

        .probe-item::before {{
            content: '';
            position: absolute;
            left: -38px;
            top: 25px;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: #00e5ff;
            border: 4px solid #0a0e27;
            box-shadow: 0 0 20px rgba(0, 229, 255, 0.5);
        }}

        .probe-item.success::before {{
            background: #22c55e;
            box-shadow: 0 0 20px rgba(34, 197, 94, 0.5);
        }}

        .probe-item.partial::before {{
            background: #eab308;
            box-shadow: 0 0 20px rgba(234, 179, 8, 0.5);
        }}

        .probe-item.failed::before {{
            background: #ef4444;
            box-shadow: 0 0 20px rgba(239, 68, 68, 0.5);
        }}

        .probe-header {{
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }}

        .probe-name {{
            font-size: 20px;
            font-weight: 600;
            color: #fff;
        }}

        .probe-status {{
            padding: 8px 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 700;
            text-transform: uppercase;
        }}

        .status-success {{
            background: #22c55e;
            color: #fff;
        }}

        .status-partial {{
            background: #eab308;
            color: #000;
        }}

        .status-failed {{
            background: #ef4444;
            color: #fff;
        }}

        .probe-source {{
            font-size: 14px;
            color: #888;
            margin-bottom: 15px;
        }}

        .probe-confidence {{
            font-size: 16px;
            color: #00e5ff;
            margin: 10px 0;
        }}

        .probe-extracted {{
            background: rgba(0, 0, 0, 0.4);
            border: 1px solid rgba(0, 229, 255, 0.3);
            border-radius: 8px;
            padding: 15px;
            margin: 15px 0;
            font-family: 'Courier New', monospace;
            color: #22c55e;
            font-size: 14px;
        }}

        .probe-details {{
            font-size: 14px;
            color: #ccc;
            margin-top: 15px;
            line-height: 1.6;
        }}

        /* APT Attribution */
        .apt-card {{
            background: linear-gradient(135deg, rgba(239, 68, 68, 0.15) 0%, rgba(239, 68, 68, 0.05) 100%);
            border: 2px solid #ef4444;
            border-radius: 16px;
            padding: 40px;
        }}

        .apt-header {{
            display: flex;
            align-items: center;
            gap: 20px;
            margin-bottom: 30px;
        }}

        .apt-icon {{
            font-size: 48px;
            color: #ef4444;
        }}

        .apt-info h3 {{
            font-size: 32px;
            color: #ef4444;
            margin-bottom: 10px;
        }}

        .apt-confidence {{
            font-size: 18px;
            color: #00e5ff;
        }}

        .apt-section {{
            margin: 30px 0;
        }}

        .apt-section-title {{
            font-size: 20px;
            font-weight: 600;
            color: #00e5ff;
            margin-bottom: 15px;
        }}

        .apt-list {{
            list-style: none;
            padding-left: 0;
        }}

        .apt-list li {{
            padding: 12px 20px;
            margin: 10px 0;
            background: rgba(0, 0, 0, 0.3);
            border-left: 4px solid #00e5ff;
            border-radius: 4px;
        }}

        /* Recommendations */
        .recommendation-card {{
            background: linear-gradient(135deg, rgba(0, 229, 255, 0.15) 0%, rgba(0, 168, 204, 0.05) 100%);
            border: 2px solid #00e5ff;
            border-radius: 16px;
            padding: 30px;
            display: flex;
            gap: 20px;
        }}

        .recommendation-icon {{
            font-size: 48px;
            color: #00e5ff;
        }}

        .recommendation-content {{
            flex: 1;
        }}

        .recommendation-title {{
            font-size: 24px;
            font-weight: 600;
            color: #00e5ff;
            margin-bottom: 15px;
        }}

        .recommendation-text {{
            font-size: 16px;
            line-height: 1.8;
            color: #e0e0e0;
        }}

        /* Footer */
        .report-footer {{
            background: rgba(10, 14, 39, 0.8);
            padding: 40px 60px;
            text-align: center;
            border-top: 2px solid rgba(0, 229, 255, 0.3);
        }}

        .footer-text {{
            font-size: 14px;
            color: #888;
            margin: 10px 0;
        }}

        .footer-logo {{
            font-size: 24px;
            font-weight: 700;
            color: #00e5ff;
            margin-top: 20px;
        }}

        /* Print Styles */
        @media print {{
            body {{
                background: #fff;
                color: #000;
            }}

            .report-container {{
                box-shadow: none;
                background: #fff;
            }}

            .section {{
                page-break-inside: avoid;
            }}

            .report-header {{
                page-break-after: avoid;
            }}
        }}

        /* Responsive */
        @media (max-width: 768px) {{
            .report-body {{
                padding: 30px;
            }}

            .report-header {{
                padding: 30px;
            }}

            .report-title {{
                font-size: 32px;
            }}

            .charts-grid {{
                grid-template-columns: 1fr;
            }}

            .detection-grid {{
                grid-template-columns: 1fr;
            }}
        }}
    </style>
</head>
<body>
    <div class="report-container">
        <!-- Header -->
        <div class="report-header">
            <div class="header-content">
                <div class="report-title">
                    <i class="fas fa-shield-halved"></i> StegoGuard Forensic Report
                </div>
                <div class="report-subtitle">
                    Advanced Steganography Detection & Analysis
                </div>
                <div class="header-meta">
                    <div class="meta-item">
                        <div class="meta-label">Report ID</div>
                        <div class="meta-value">{self.report_id}</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Generated</div>
                        <div class="meta-value">{datetime.now().strftime('%Y-%m-%d %H:%M:%S UTC')}</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Version</div>
                        <div class="meta-value">StegoGuard Pro 1.6</div>
                    </div>
                    <div class="meta-item">
                        <div class="meta-label">Classification</div>
                        <div class="meta-value">CONFIDENTIAL</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Body -->
        <div class="report-body">
            <!-- File Information Section -->
            <div class="section">
                <div class="section-header">
                    <i class="fas fa-file-image"></i>
                    <h2 class="section-title">File Information</h2>
                </div>
                <div class="threat-stats-grid">
                    <div class="stat-card">
                        <div class="stat-label">Filename</div>
                        <div class="stat-value" style="font-size: 20px; word-break: break-all;">
                            {file_info.get('filename', 'N/A')}
                        </div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">File Size</div>
                        <div class="stat-value">{file_info.get('size', 0) / 1024 / 1024:.2f}</div>
                        <div class="stat-subvalue">MB</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Dimensions</div>
                        <div class="stat-value" style="font-size: 24px;">{file_info.get('dimensions', 'N/A')}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Format</div>
                        <div class="stat-value" style="font-size: 32px;">{file_info.get('format', 'N/A')}</div>
                    </div>
                </div>
                <div style="margin-top: 25px; padding: 20px; background: rgba(0, 0, 0, 0.3); border-radius: 12px;">
                    <div style="font-size: 14px; color: #888; margin-bottom: 10px;">SHA256 Hash</div>
                    <div style="font-family: 'Courier New', monospace; color: #00e5ff; font-size: 14px; word-break: break-all;">
                        {file_info.get('sha256', 'N/A')}
                    </div>
                </div>
            </div>

            <!-- Threat Assessment Section -->
            <div class="section">
                <div class="section-header">
                    <i class="fas fa-shield-virus"></i>
                    <h2 class="section-title">Threat Assessment</h2>
                </div>
                <div class="threat-card">
                    <div class="threat-content">
                        <div class="threat-level-badge">
                            <i class="fas fa-exclamation-triangle"></i> {threat_level}
                        </div>
                        <div class="threat-stats-grid">
                            <div class="stat-card">
                                <div class="stat-label">Confidence Level</div>
                                <div class="stat-value">{int(confidence * 100)}</div>
                                <div class="stat-subvalue">%</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Anomalies Detected</div>
                                <div class="stat-value">{anomaly_count}</div>
                                <div class="stat-subvalue">findings</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Detection Score</div>
                                <div class="stat-value">{int(detection_score * 100)}</div>
                                <div class="stat-subvalue">%</div>
                            </div>
                            <div class="stat-card">
                                <div class="stat-label">Avg Confidence</div>
                                <div class="stat-value">{int(avg_confidence * 100)}</div>
                                <div class="stat-subvalue">%</div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Visualization Section -->
            <div class="section">
                <div class="section-header">
                    <i class="fas fa-chart-pie"></i>
                    <h2 class="section-title">Visual Analysis</h2>
                </div>
                <div class="charts-grid">
                    <div class="chart-card">
                        <div class="chart-title">Detection Overview</div>
                        <div class="chart-container">
                            <canvas id="detectionChart"></canvas>
                        </div>
                    </div>
                    <div class="chart-card">
                        <div class="chart-title">Severity Distribution</div>
                        <div class="chart-container">
                            <canvas id="severityChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detection Results Section -->
            <div class="section">
                <div class="section-header">
                    <i class="fas fa-magnifying-glass-chart"></i>
                    <h2 class="section-title">Detection Results</h2>
                </div>
                <div class="detection-grid">
"""

        # Add detection results
        for detection in detection_results:
            detected = detection.get('detected', False)
            detector_name = detection.get('detector', 'Unknown')
            confidence_val = detection.get('confidence', 0)
            severity = detection.get('severity', 'unknown').lower()
            details = detection.get('details', 'No details available.')
            detection_type = detection.get('type', '')

            status_class = 'detected' if detected else 'clean'
            status_text = 'DETECTED' if detected else 'CLEAN'
            status_badge_class = 'status-detected' if detected else 'status-clean'
            severity_class = f'severity-{severity}'

            html += f"""
                    <div class="detection-card {status_class}">
                        <div class="detection-header">
                            <div class="detection-name">
                                <i class="fas fa-{'triangle-exclamation' if detected else 'check-circle'}"></i>
                                {detector_name}
                            </div>
                            <div class="detection-status {status_badge_class}">
                                {status_text}
                            </div>
                        </div>
                        <div class="detection-confidence">
                            Confidence: {int(confidence_val * 100)}%
                        </div>
                        <div class="detection-severity {severity_class}">
                            {severity.upper()}
                        </div>
                        <div class="detection-details">
                            {details}
                        </div>
                        {f'<div class="detection-type"><strong>Type:</strong> {detection_type}</div>' if detection_type else ''}
                    </div>
"""

        html += """
                </div>
            </div>
"""

        # Decryption Results Section
        if decryption_activated and probes:
            html += f"""
            <!-- Decryption Results Section -->
            <div class="section">
                <div class="section-header">
                    <i class="fas fa-key"></i>
                    <h2 class="section-title">Decryption Analysis</h2>
                </div>

                <div class="progress-bar-container">
                    <div class="progress-label">
                        <span>Overall Success Rate</span>
                        <span>{int(overall_success_rate * 100)}%</span>
                    </div>
                    <div class="progress-bar">
                        <div class="progress-fill" style="width: {int(overall_success_rate * 100)}%;">
                            {int(overall_success_rate * 100)}% Decrypted
                        </div>
                    </div>
                </div>

                <div class="threat-stats-grid" style="margin: 30px 0;">
                    <div class="stat-card">
                        <div class="stat-label">Success Rate</div>
                        <div class="stat-value">{int(overall_success_rate * 100)}</div>
                        <div class="stat-subvalue">%</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Time Taken</div>
                        <div class="stat-value">{decryption_results.get('time_taken', 0)}</div>
                        <div class="stat-subvalue">seconds</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Data Extracted</div>
                        <div class="stat-value" style="font-size: 28px;">{decryption_results.get('total_extracted', 'N/A')}</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-label">Probes Used</div>
                        <div class="stat-value">{len(probes)}</div>
                        <div class="stat-subvalue">methods</div>
                    </div>
                </div>

                <div class="probe-timeline">
"""

            # Add probe results
            for idx, probe in enumerate(probes, 1):
                probe_name = probe.get('name', f'Probe {idx}')
                probe_source = probe.get('source', 'N/A')
                probe_success = probe.get('success', False)
                probe_partial = probe.get('partial_success', False)
                probe_confidence = probe.get('confidence', 0)
                probe_extracted = probe.get('extracted', '')
                probe_details = probe.get('details', '')

                if probe_success:
                    status_class = 'success'
                    status_text = 'SUCCESS'
                    status_badge = 'status-success'
                elif probe_partial:
                    status_class = 'partial'
                    status_text = 'PARTIAL'
                    status_badge = 'status-partial'
                else:
                    status_class = 'failed'
                    status_text = 'FAILED'
                    status_badge = 'status-failed'

                html += f"""
                    <div class="probe-item {status_class}">
                        <div class="probe-header">
                            <div class="probe-name">{probe_name}</div>
                            <div class="probe-status {status_badge}">
                                <i class="fas fa-{'check-circle' if probe_success else 'exclamation-circle' if probe_partial else 'times-circle'}"></i>
                                {status_text}
                            </div>
                        </div>
                        <div class="probe-source">
                            <i class="fas fa-arrow-right"></i> {probe_source}
                        </div>
                        <div class="probe-confidence">
                            Confidence: {int(probe_confidence * 100)}%
                        </div>
                        {f'<div class="probe-extracted"><strong>Extracted Data:</strong><br>{probe_extracted}</div>' if probe_extracted else ''}
                        {f'<div class="probe-details">{probe_details}</div>' if probe_details else ''}
                    </div>
"""

            # Add recommendation if available
            recommendation = decryption_results.get('recommendation', '')
            if recommendation:
                html += f"""
                </div>
                <div class="recommendation-card" style="margin-top: 30px;">
                    <div class="recommendation-icon">
                        <i class="fas fa-lightbulb"></i>
                    </div>
                    <div class="recommendation-content">
                        <div class="recommendation-title">Recommendation</div>
                        <div class="recommendation-text">{recommendation}</div>
                    </div>
                </div>
            </div>
"""
            else:
                html += """
                </div>
            </div>
"""

        # APT Attribution Section
        apt_match = threat_intel.get('apt_match', '')
        if apt_match:
            apt_confidence = threat_intel.get('confidence', 0)
            techniques = threat_intel.get('techniques', [])
            iocs = threat_intel.get('iocs', [])

            html += f"""
            <!-- APT Attribution Section -->
            <div class="section">
                <div class="section-header">
                    <i class="fas fa-user-secret"></i>
                    <h2 class="section-title">Threat Intelligence</h2>
                </div>
                <div class="apt-card">
                    <div class="apt-header">
                        <div class="apt-icon">
                            <i class="fas fa-skull-crossbones"></i>
                        </div>
                        <div class="apt-info">
                            <h3>{apt_match}</h3>
                            <div class="apt-confidence">
                                Attribution Confidence: {int(apt_confidence * 100)}% (HIGH)
                            </div>
                        </div>
                    </div>

                    {f'''
                    <div class="apt-section">
                        <div class="apt-section-title">
                            <i class="fas fa-tools"></i> Known Techniques (TTPs)
                        </div>
                        <ul class="apt-list">
                            {''.join(f'<li><i class="fas fa-chevron-right"></i> {tech}</li>' for tech in techniques)}
                        </ul>
                    </div>
                    ''' if techniques else ''}

                    {f'''
                    <div class="apt-section">
                        <div class="apt-section-title">
                            <i class="fas fa-fingerprint"></i> Indicators of Compromise (IOCs)
                        </div>
                        <ul class="apt-list">
                            {''.join(f'<li><i class="fas fa-exclamation-circle"></i> {ioc}</li>' for ioc in iocs)}
                        </ul>
                    </div>
                    ''' if iocs else ''}
                </div>
            </div>
"""

        # Footer
        html += f"""
        </div>

        <!-- Footer -->
        <div class="report-footer">
            <div class="footer-text">
                This report is generated by StegoGuard Pro - Advanced Steganography Detection System
            </div>
            <div class="footer-text">
                Report ID: {self.report_id} | Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S UTC')}
            </div>
            <div class="footer-text">
                © 2026 StegoGuard. Confidential - For Authorized Personnel Only
            </div>
            <div class="footer-logo">
                <i class="fas fa-shield-halved"></i> StegoGuard Pro
            </div>
        </div>
    </div>

    <!-- Chart.js Initialization -->
    <script>
        // Detection Overview Chart
        const detectionCtx = document.getElementById('detectionChart').getContext('2d');
        new Chart(detectionCtx, {{
            type: 'doughnut',
            data: {{
                labels: ['Detected', 'Clean'],
                datasets: [{{
                    data: [{detected_count}, {clean_count}],
                    backgroundColor: [
                        'rgba(239, 68, 68, 0.8)',
                        'rgba(34, 197, 94, 0.8)'
                    ],
                    borderColor: [
                        '#ef4444',
                        '#22c55e'
                    ],
                    borderWidth: 2
                }}]
            }},
            options: {{
                responsive: true,
                maintainAspectRatio: false,
                plugins: {{
                    legend: {{
                        position: 'bottom',
                        labels: {{
                            color: '#e0e0e0',
                            font: {{
                                size: 14
                            }}
                        }}
                    }},
                    title: {{
                        display: false
                    }}
                }}
            }}
        }});

        // Severity Distribution Chart
        const severityCtx = document.getElementById('severityChart').getContext('2d');
        new Chart(severityCtx, {{
            type: 'bar',
            data: {{
                labels: ['Critical', 'High', 'Medium', 'Low'],
                datasets: [{{
                    label: 'Detections',
                    data: [
                        {severity_counts['critical']},
                        {severity_counts['high']},
                        {severity_counts['medium']},
                        {severity_counts['low']}
                    ],
                    backgroundColor: [
                        'rgba(239, 68, 68, 0.8)',
                        'rgba(249, 115, 22, 0.8)',
                        'rgba(234, 179, 8, 0.8)',
                        'rgba(34, 197, 94, 0.8)'
                    ],
                    borderColor: [
                        '#ef4444',
                        '#f97316',
                        '#eab308',
                        '#22c55e'
                    ],
                    borderWidth: 2
                }}]
            }},
            options: {{
                responsive: true,
                maintainAspectRatio: false,
                plugins: {{
                    legend: {{
                        display: false
                    }}
                }},
                scales: {{
                    y: {{
                        beginAtZero: true,
                        ticks: {{
                            color: '#e0e0e0',
                            stepSize: 1
                        }},
                        grid: {{
                            color: 'rgba(255, 255, 255, 0.1)'
                        }}
                    }},
                    x: {{
                        ticks: {{
                            color: '#e0e0e0'
                        }},
                        grid: {{
                            color: 'rgba(255, 255, 255, 0.1)'
                        }}
                    }}
                }}
            }}
        }});

        // Animate progress bars on load
        window.addEventListener('load', () => {{
            const progressBars = document.querySelectorAll('.progress-fill');
            progressBars.forEach(bar => {{
                const width = bar.style.width;
                bar.style.width = '0%';
                setTimeout(() => {{
                    bar.style.width = width;
                }}, 500);
            }});
        }});
    </script>
</body>
</html>
"""

        return html

    def generate_text_report(self, analysis_results: Dict) -> str:
        """Generate professional text-based forensic report"""

        file_info = analysis_results.get('file_info', {})
        threat_level = analysis_results.get('threat_level', 'unknown').upper()
        confidence = analysis_results.get('confidence', 0)
        anomaly_count = analysis_results.get('anomaly_count', 0)
        detection_results = analysis_results.get('detection_results', [])
        decryption_results = analysis_results.get('decryption_results', {})
        threat_intel = analysis_results.get('threat_intel', {})

        report = f"""
╔══════════════════════════════════════════════════════════════════════════╗
║                    STEGOGUARD FORENSIC REPORT                           ║
╚══════════════════════════════════════════════════════════════════════════╝

Report ID: {self.report_id}
Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S UTC')}
Version: StegoGuard Pro 1.6 (Hardened Mode, Offline)

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FILE INFORMATION
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

File Analyzed: {file_info.get('filename', 'N/A')}
SHA256: {file_info.get('sha256', 'N/A')}
Size: {file_info.get('size', 0) / 1024 / 1024:.2f} MB
Dimensions: {file_info.get('dimensions', 'N/A')}
Format: {file_info.get('format', 'N/A')}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
THREAT ASSESSMENT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Threat Level: {threat_level}
Confidence: {int(confidence * 100)}%
Anomalies Detected: {anomaly_count}
Steganography Detected: {'YES' if analysis_results.get('steganography_detected', False) else 'NO'}

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DETECTION BREAKDOWN
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

"""

        for idx, detection in enumerate(detection_results, 1):
            detected = detection.get('detected', False)
            detector_name = detection.get('detector', 'Unknown')
            confidence_val = detection.get('confidence', 0)
            severity = detection.get('severity', 'unknown').upper()
            details = detection.get('details', 'No details available.')
            detection_type = detection.get('type', 'N/A')

            status = '⚠️  DETECTED' if detected else '✓ CLEAN'

            report += f"""
{idx}. {detector_name} - {status}
   Confidence: {int(confidence_val * 100)}%
   Severity: {severity}
   Type: {detection_type}
   Details: {details}

"""

        if decryption_results.get('activated', False):
            overall_success = decryption_results.get('overall_success_rate', 0)
            probes = decryption_results.get('probes', [])

            report += f"""
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
DECRYPTION ANALYSIS
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

Overall Success Rate: {int(overall_success * 100)}%
Time Taken: {decryption_results.get('time_taken', 0)} seconds
Data Extracted: {decryption_results.get('total_extracted', 'N/A')}
Probes Used: {len(probes)}

PROBE RESULTS:
"""

            for idx, probe in enumerate(probes, 1):
                probe_name = probe.get('name', f'Probe {idx}')
                probe_source = probe.get('source', 'N/A')
                probe_success = probe.get('success', False)
                probe_partial = probe.get('partial_success', False)
                probe_confidence = probe.get('confidence', 0)
                probe_extracted = probe.get('extracted', 'None')
                probe_details = probe.get('details', 'N/A')

                if probe_success:
                    status = '✓ SUCCESS'
                elif probe_partial:
                    status = '⚡ PARTIAL'
                else:
                    status = '✗ FAILED'

                report += f"""
{idx}. {probe_name} - {status}
   Source: {probe_source}
   Confidence: {int(probe_confidence * 100)}%
   Extracted: {probe_extracted}
   Details: {probe_details}

"""

            recommendation = decryption_results.get('recommendation', '')
            if recommendation:
                report += f"""
RECOMMENDATION:
{recommendation}

"""

        if threat_intel.get('apt_match'):
            apt_match = threat_intel.get('apt_match', '')
            apt_confidence = threat_intel.get('confidence', 0)
            techniques = threat_intel.get('techniques', [])
            iocs = threat_intel.get('iocs', [])

            report += f"""
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
THREAT INTELLIGENCE
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

APT Group: {apt_match}
Attribution Confidence: {int(apt_confidence * 100)}% (HIGH)

KNOWN TECHNIQUES (TTPs):
"""
            for tech in techniques:
                report += f"  • {tech}\n"

            report += "\nINDICATORS OF COMPROMISE (IOCs):\n"
            for ioc in iocs:
                report += f"  • {ioc}\n"

        report += f"""

━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
FINAL ASSESSMENT
━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

This file has been analyzed using StegoGuard Pro's advanced detection
algorithms. The analysis reveals {threat_level} threat level with {int(confidence * 100)}%
confidence. Immediate investigation and response recommended.

Report ID: {self.report_id}
Generated: {datetime.now().strftime('%Y-%m-%d %H:%M:%S UTC')}

═══════════════════════════════════════════════════════════════════════════
                    END OF REPORT - CONFIDENTIAL
═══════════════════════════════════════════════════════════════════════════
"""

        return report
